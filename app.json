{
  "expo": {
    "name": "ExpiTrack",
    "slug": "expitrack",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "backgroundColor": "#0e0e12"
    },
    "ios": {
      "bundleIdentifier": "com.tonnom.expitrack",
      "supportsTablet": false
    },
    "android": {
      "package": "com.tonnom.expitrack",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0e0e12"
      }
    },
    "plugins": [
      ["expo-notifications", { "color": "#e8825a" }]
    ]
  }
}